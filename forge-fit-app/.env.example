# Copy this file to .env and fill in real values. .env is gitignored.
# These keys are read at build time via expo-constants.

# Google AI Studio key (free tier). Get one at https://aistudio.google.com/app/apikey
EXPO_PUBLIC_GEMINI_API_KEY=

# WHOOP developer app credentials. Create one at https://developer.whoop.com/
# The redirect URI registered with WHOOP should be: forgefit://whoop-callback
EXPO_PUBLIC_WHOOP_CLIENT_ID=
EXPO_PUBLIC_WHOOP_CLIENT_SECRET=
